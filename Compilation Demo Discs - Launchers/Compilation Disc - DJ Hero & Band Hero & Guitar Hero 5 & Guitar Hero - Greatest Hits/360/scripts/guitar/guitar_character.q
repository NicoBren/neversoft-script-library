script create_camera_lock_target 
	CreateFromStructure {
		name = <name>
		pos = (0.0, 0.0, 0.0)
		angles = (0.0, 1.0, 0.0)
		Class = GameObject
		type = Ghost
		CreatedAtStart
		disableshadowcasting = false
		profile = $Profile_Ven_Camera_Obj
		only_animate_if_locked_to_by_active_cinematic_camera = true
	}
endscript

