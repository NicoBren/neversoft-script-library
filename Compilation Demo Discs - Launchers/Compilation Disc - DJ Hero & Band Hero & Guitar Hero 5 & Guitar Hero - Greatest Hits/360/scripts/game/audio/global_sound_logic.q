		vol = -2
		pan1x = 0.0
		pan1y = 1.0
		buss = Master}
	Wait \{2
		seconds}
	PlaySound \{TestTone_PinkNoise_12db
		vol = -2
		pan1x = 1.0
		pan1y = 1.0
		buss = Master}
	Wait \{2
		seconds}
	PlaySound \{TestTone_PinkNoise_12db
		vol = -2
