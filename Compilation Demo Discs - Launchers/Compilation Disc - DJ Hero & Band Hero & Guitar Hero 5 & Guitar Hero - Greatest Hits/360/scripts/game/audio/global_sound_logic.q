		endif
		if (<part> = Bass)
			printf \{channel = sfx
				qs("\L****************Part is BASS")}
			if isSinglePlayerGame
				printf \{channel = sfx
					qs("\L****************Part is BASS and we ARE in a singleplayer game")}
				setsoundbusseffects \{effects = [
						{
							effect = echo
							name = starpowerecho
							wetmix = 0.3
