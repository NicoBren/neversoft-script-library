script GH3_Play_A_Crowd_OneShot_Negative_Based_On_Venue 
	printf \{channel = sfx
		'HELLLLLLLLLLLLLLLo'}
	SoundEvent \{event = Crowd_Reaction_Bad_L}
	SoundEvent \{event = Crowd_Reaction_Bad_R}
