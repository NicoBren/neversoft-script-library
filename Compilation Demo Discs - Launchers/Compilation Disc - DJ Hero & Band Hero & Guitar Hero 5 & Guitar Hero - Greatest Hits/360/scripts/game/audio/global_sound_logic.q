			vol = -100.0
		}}
	SoundBussLock \{User_Sfx}
	SoundBussUnlock \{User_Band}
	SetSoundBussParams \{User_Band = {
			vol = -100.0
		}}
	SoundBussLock \{User_Band}
	begin
	PlaySound \{TestTone_PinkNoise_12db
		vol = -2
		pan1x = -1.0
		pan1y = 1.0
		buss = Master}
	Wait \{2
		seconds}
