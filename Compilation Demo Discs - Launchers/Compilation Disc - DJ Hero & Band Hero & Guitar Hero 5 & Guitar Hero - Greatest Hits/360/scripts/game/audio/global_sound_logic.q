		qs("\LSinglePlayer")}
	if NOT (($is_attract_mode = 1) || ($crowd_in_jam_mode_song_state = 1) || ($game_mode = p2_battle))
		if (<combo> < 100)
			SoundEvent \{event = UI_SFX_50_Note_Streak_SinglePlayer}
