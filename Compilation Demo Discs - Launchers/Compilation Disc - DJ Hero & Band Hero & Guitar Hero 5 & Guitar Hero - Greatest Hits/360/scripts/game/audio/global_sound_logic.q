		endif
		if (<part> = drum)
			printf \{channel = sfx
				qs("\L****************Part is DRUM")}
			if isSinglePlayerGame
				printf \{channel = sfx
					qs("\L****************Part is DRUM and we ARE in a singleplayer game")}
				setsoundbusseffects \{effects = [
						{
							effect = echo
