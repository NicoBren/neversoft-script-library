script get_song_original_artist \{song = invalid}
	if StructureContains Structure = $gh_songlist_props <song>
		return original_artist = ($gh_songlist_props.<song>.original_artist)
	endif
	printstruct <...>
	ScriptAssert \{qs("\LSong not found")}
endscript

