script build_cas_editable_list 
	switch (<cas_type>)
		case CAS_FULL_PARTS
		return cas_editable_list = ($cas_full_parts_pak_contents)
		case CAS_GLOBALPAK
		return cas_editable_list = ($cas_global_pak_contents)
		case CAS_PRESET_TEXSWAPS
		return cas_editable_list = ($cas_preset_texswaps_pak_contents)
		case cas_female_bodypak
		return cas_editable_list = ($cas_female_body_pak_contents)
		case cas_male_bodypak
		return cas_editable_list = ($cas_male_body_pak_contents)
		case cas_female_accpak
		return cas_editable_list = ($cas_female_accessory_pak_contents)
		case cas_male_accpak
		return cas_editable_list = ($cas_male_accessory_pak_contents)
		case cas_female_torsopak
		return cas_editable_list = ($cas_female_torso_pak_contents)
		case cas_male_torsopak
		return cas_editable_list = ($cas_male_torso_pak_contents)
		case cas_female_legspak
		return cas_editable_list = ($cas_female_legs_pak_contents)
		case cas_male_legspak
		return cas_editable_list = ($cas_male_legs_pak_contents)
		case cas_female_shoespak
		return cas_editable_list = ($cas_female_shoes_pak_contents)
		case cas_male_shoespak
		return cas_editable_list = ($cas_male_shoes_pak_contents)
		case cas_guitarpak
		return cas_editable_list = ($cas_guitar_pak_contents)
		case cas_guitarpak_finishes_0
		return cas_editable_list = ($cas_guitar_pak_finishes_0_contents)
		case cas_guitarpak_finishes_1
		return cas_editable_list = ($cas_guitar_pak_finishes_1_contents)
		case cas_guitarpak_finishes_2
		return cas_editable_list = ($cas_guitar_pak_finishes_2_contents)
		case cas_guitarpak_nh
		return cas_editable_list = ($cas_guitar_pak_nh_contents)
		case cas_basspak
		return cas_editable_list = ($cas_bass_pak_contents)
		case cas_basspak_finishes_0
		return cas_editable_list = ($cas_bass_pak_finishes_0_contents)
		case cas_basspak_finishes_1
		return cas_editable_list = ($cas_bass_pak_finishes_1_contents)
		case cas_basspak_finishes_2
		return cas_editable_list = ($cas_bass_pak_finishes_2_contents)
		case cas_basspak_nh
		return cas_editable_list = ($cas_bass_pak_nh_contents)
		case cas_drumspak
		return cas_editable_list = ($cas_drums_pak_contents)
		case cas_vocalspak
		return cas_editable_list = ($cas_vocals_pak_contents)
		case CAS_DEFORM
		return cas_editable_list = ($master_editable_list)
		case CAS_CAPTEXTURES
		return cas_editable_list = ($master_editable_list)
		case CAS_COMPRESS_TABLE_16
		return cas_editable_list = ($master_editable_list)
		case CAS_AGORA
		return cas_editable_list = ($master_editable_list)
		case CAS_ARCHIVE
		return cas_editable_list = ($master_editable_list)
		case CAS_PARTS
		return cas_editable_list = ($master_editable_list)
		default
		ScriptAssert \{'Bad CAS Pak'}
	endswitch
endscript
