						}
					]}
				setsoundbusseffects \{effects = [
						{
							effect = sfxreverb
							name = starpowerreverb
							DryLevel = -1400.0
							reverblevel = 900
							ReflectionsLevel = 0
							Room = -2000
							RoomRollOffFactor = 18
							ReverbDelay = 0.1
							DecayTime = 0.1
							roomhf = -1
						}
					]
					time = 0.1}
				SongSetStarpowerEffectsSendVolume player = <player> vol = 8
			else
