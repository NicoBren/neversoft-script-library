script StopNotes_01 
	if isSoundEventPlaying \{Tutorial_String_1_Strum_Free}
		SetSoundParams \{Tutorial_String_1_Strum_Free
			vol_percent = 100}
		Wait \{0.05
			seconds}
		SetSoundParams \{Tutorial_String_1_Strum_Free
			vol_percent = 50}
		Wait \{0.05
			seconds}
		SetSoundParams \{Tutorial_String_1_Strum_Free
			vol_percent = 10}
		StopSoundEvent \{Tutorial_String_1_Strum_Free}
	endif
endscript

